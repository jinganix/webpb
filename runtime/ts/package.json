{
  "name": "webpb",
  "version": "0.0.32",
  "description": "webpb TypeScript runtime and protoc code generation CLI",
  "scripts": {
    "build": "rimraf build && tsc && vite build && dts-bundle-generator --config ./dts-bundle-generator.config.cjs && tsc -p tsconfig.cli.json && node scripts/prepare-build.mjs && copyfiles ./README.md build",
    "check": "npm run lint && npm run test",
    "lint": "eslint --quiet src",
    "lint:fix": "eslint --fix src",
    "deploy": "npm run check && npm run release",
    "release": "npm run sync-version && npm run build && npm publish ./build --access public --ignore-scripts",
    "sync-version": "node scripts/sync-version.mjs",
    "test": "vitest --coverage"
  },
  "author": "jinganix@gmail.com",
  "license": "Apache-2.0",
  "bin": {
    "webpb": "./cli/bin/webpb.js"
  },
  "files": [
    "cli",
    "dist",
    "proto",
    "webpb-version.properties",
    "README.md"
  ],
  "keywords": [
    "webpb",
    "protobuf",
    "protoc",
    "runtime"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jinganix/webpb"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./proto": "./proto",
    "./proto/*": "./proto/*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "copyfiles": "^2.4.1",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-quotes": "^0.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
