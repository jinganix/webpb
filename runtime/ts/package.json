{
  "name": "webpb",
  "version": "0.0.20",
  "description": "The webpb runtime library",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rimraf build/**/* && tsc && vite build && dts-bundle-generator --config ./dts-bundle-generator.config.ts && copyfiles ./README.md ./package.json build",
    "check": "npm run lint && npm run test",
    "lint": "eslint --quiet src/**/*.ts",
    "lint:fix": "eslint --fix src/**/*.ts",
    "deploy": "npm run check && npm run build && npm publish ./build --access public",
    "test": "jest --forceExit --coverage --verbose --detectOpenHandles"
  },
  "author": "jinganix@gmail.com",
  "license": "Apache-2.0",
  "keywords": [
    "webpb",
    "runtime"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jinganix/webpb"
  },
  "module": "./dist/webpb.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/webpb.js"
    },
    "./dist/": {
      "import": "./dist/"
    }
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-import-quotes": "^0.0.1",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "pretty-quick": "^4.0.0",
    "rimraf": "^6.0.1",
    "copyfiles": "^2.4.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0",
    "vite": "^6.0.3"
  }
}
