{
  "compilerOptions": {
    "allowJs": false,
    "alwaysStrict": true,
    "baseUrl": "./",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "lib": ["DOM", "ES2015", "ES2022.Error"],
    "module": "commonjs",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "pretty": true,
    "removeComments": true,
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "target": "es6",
    "paths": {
      "@proto/*": ["generated/proto/*"],
      "@scripts/*": ["src/scripts/*"]
    },
    "typeRoots": ["node_modules/@types"]
  },
  "include": [
    "generated/**/*.ts",
    "src/scripts/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
