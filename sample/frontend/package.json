{
  "name": "webpb-frontend",
  "version": "0.0.1",
  "description": "A sample frontend",
  "scripts": {
    "build": "npm run proto && cross-env NODE_ENV=production webpack --config webpack/webpack.config.prod.js",
    "check": "npm run proto && npm run lint && npm run test",
    "dev": "webpack serve --config webpack/webpack.config.dev.js",
    "lint": "npm run lint:scripts",
    "lint:scripts": "eslint src",
    "proto": "node scripts/generate-proto.mjs",
    "start": "npm run proto && npm run dev",
    "test": "jest --forceExit --coverage --silent --detectOpenHandles"
  },
  "license": "Apache-2.0",
  "keywords": [
    "webpb",
    "sample",
    "frontend"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "^7.29.7",
    "@eslint/compat": "^2.1.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^10.1.1",
    "clean-webpack-plugin": "^4.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-quotes": "^0.0.1",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.4",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4",
    "webpack-merge": "^6.0.1",
    "webpb": "^0.0.25"
  },
  "dependencies": {
    "@babel/polyfill": "^7.12.1",
    "axios": "^1.17.0",
    "core-js": "^3.49.0",
    "jest-util": "^30.4.1"
  }
}
