{
  "name": "webpb-frontend",
  "version": "0.0.1",
  "description": "A sample frontend",
  "type": "module",
  "scripts": {
    "backend": "cd ../.. && ./gradlew sample:backend:bootRun --no-daemon",
    "build": "npm run proto && tsc --noEmit && vite build",
    "check": "npm run proto && npm run lint && npm run test",
    "dev": "node scripts/check-backend.mjs && vite",
    "dev:wait": "node scripts/wait-for-backend.mjs && vite",
    "lint": "eslint src",
    "proto": "webpb generate -o generated/proto -I ../../sample/proto/src/main/resources ../../sample/proto/src/main/resources/Common.proto ../../sample/proto/src/main/resources/Options.proto",
    "preview": "vite preview",
    "start": "npm run proto && node scripts/check-backend.mjs && vite",
    "start:all": "npm run proto && concurrently -k -n backend,frontend -c blue,green \"npm run backend\" \"npm run dev:wait\"",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:ci": "node scripts/install-playwright.mjs"
  },
  "license": "Apache-2.0",
  "keywords": [
    "webpb",
    "sample",
    "frontend"
  ],
  "dependencies": {
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "webpb": "file:../../runtime/ts/build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
